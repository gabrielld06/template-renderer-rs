{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Example Schema",
    "type": "object",
    "properties": {
        "projectName": {
            "type": "string",
            "description": "The name of the project",
            "default": "my-project"
        },
        "helloTo": {
            "type": "string"
        },
        "file": {
            "type": "string"
        }
    },
    "required": ["projectName", "helloTo", "file"]
}
